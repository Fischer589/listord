NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ADMIN_WHATSAPP_PHONE=18090000000
NEXT_PUBLIC_APP_URL=http://localhost:3000

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEEKLY_PRICE_ID=
STRIPE_MONTHLY_PRICE_ID=

# Nunca pongas SUPABASE_SERVICE_ROLE_KEY en variables NEXT_PUBLIC_*.
# La service role key solo debe vivir en entornos privados de servidor.
SUPABASE_SERVICE_ROLE_KEY=
WORKER_PHOTOS_BUCKET=worker-photos

# Admin panel authentication (Phase 0)
# ADMIN_USERNAME: choose a username for /admin access
# ADMIN_PASSWORD: use a strong random password (min 20 chars recommended)
# ADMIN_SESSION_SECRET: random 32+ char string used to sign session cookies
#   Generate with: openssl rand -hex 32
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Worker monetization (Phase 7)
# Create two Stripe products: Featured Worker (RD$199/mo) and Pro Profile (RD$299/mo)
# Paste the recurring Price IDs here:
STRIPE_WORKER_FEATURED_PRICE_ID=
STRIPE_WORKER_PRO_PRICE_ID=
